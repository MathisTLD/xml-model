{
  "name": "xml-model",
  "version": "2.0.0",
  "description": "allows transparent XML <-> Object conversion in typescript",
  "license": "MIT",
  "author": "MathisTLD",
  "repository": "git@github.com:MathisTLD/xml-model.git",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "preversion": "vitest run",
    "version": "npm run build",
    "postversion": "git push && git push --tags",
    "build": "vite build",
    "dev": "vite build --watch",
    "docs": "vite dev",
    "test": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "xml-js": "^1.6.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "marmotte": "^0.4.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.9.3",
    "vitepress": "^2.0.0-alpha.16",
    "vitepress-plugin-llms": "^1.11.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
